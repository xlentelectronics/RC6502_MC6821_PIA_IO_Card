1 PRINT CHR$(27);"[2J"; : PRINT CHR$(27);"[1;1H"
10 PRINT "* * * MC6821 PIA IO RUNNINGLIGHT * * *"
20 REM -- INITIALIZE MC6521 PIA --
30 POKE 49153,0		: REM CRA address 0xC001. Select DDRA
40 POKE 49152,255	: REM DDRA address 0xC000. Set DDRA as OUTPUT 
50 POKE 49153,4		: REM Select DRA register
60 POKE 49152,255	: REM Set DRA OUTPUTS to 1, LEDS are OFF
70 POKE 49155,0		: REM CRB ADDRESS 0xC003. Select DDRB
80 POKE 49154,255	: REM DDRB ADDRES 0xC002. Set DDRB as OUTPUT	
90 POKE 49155,4		: REM Select DRB register
100 POKE 49154,255	: REM Set DRB OUTPUTS to 1, LEDS are OFF	
110 REM -- START RUNNINGLIGHT --
115 REM -- LEFT TO RIGHT -- 
120 FOR I = 0 TO 7
130 A = (255 - INT(2^I))
140 POKE 49152,A
150 GOSUB 300
160 NEXT I
165 REM -- RIGHT TO LEFT --
170 FOR I = 6 TO 1 STEP -1
180 A = (255 - INT(2^I))
190 POKE 49152,A
200 GOSUB 300
210 NEXT I
220 GOTO 110
300 REM GOSUB -- DELAY --
310 FOR D = 1 TO 25
320 NEXT D
330 RETURN
