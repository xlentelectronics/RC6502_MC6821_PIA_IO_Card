1 PRINT CHR$(27);"[2J"; : PRINT CHR$(27);"[1;1H"
5 PRINT "* * * MC6821 PIA IO RUNNING LIGHT * * *"
10 PRINT CHR$(27);"[3;1H" : PRINT "SPEED CONTROL, 0 MAX, 150 MIN"
15 REM -- INITIALIZE MC6521 PIA ---
20 POKE 49153,0		: REM CRA address 0xC001. Select DDRA
30 POKE 49152,255	: REM DDRA address 0xC000. Set DDRA as OUTPUT 
40 POKE 49153,4		: REM Select DRA register
50 POKE 49152,255	: REM Set DRA OUTPUTS to 1, LEDS are OFF
60 POKE 49155,0		: REM CRB ADDRESS 0xC003. Select DDRB
70 POKE 49154,127	: REM DDRB ADDRES 0xC002. Set DDRB PB0~PB6 OUTPUT, PB7 as INPUT	
80 POKE 49155,4		: REM Select DRB register
90 POKE 49154,127	: REM Set DRB PB0-PB6 OUTPUTS to 1, LEDS are OFF	
100 X = 0
110 REM -- START RUNNINGLIGHT ---
120 REM -- LEFT TO RIGHT --
130 FOR I = 0 TO 7
140 A = (255 - INT(2^I))
150 POKE 49152,A
160 GOSUB 400
170 NEXT I
180 REM -- RIGHT TO LEFT --
190 FOR I = 6 TO 1 STEP -1
200 A = (255 - INT(2^I))
210 POKE 49152,A
220 GOSUB 400
230 NEXT I
240 GOTO 110
400 REM GOSUB -- DELAY --
405 Z = PEEK(49154)
410 IF (Z AND 128) =< 127 THEN X = X + 5
420 IF X > 150 THEN X = 0 
425 PRINT CHR$(27);"[5;1H" : PRINT "SPEED"; X ; "   "
430 FOR D = 0 TO X : REM DELAY
440 NEXT D
450 RETURN

